# Most Likely Bracket

The most likely bracket is constructed by selecting the higher-probability team to win each game, working forward from Round 1 through the Championship.

```{r most-likely-bracket}
# Deterministic winner using em_vec
predict_winner <- function(t1, t2) {
  p1 <- 1 / (1 + exp(-(em_vec[t1] - em_vec[t2]) / 10))
  if (p1 >= 0.5) t1 else t2
}

predict_region <- function(region_name) {
  sl <- region_slots[[region_name]]
  pairs <- get_round64_pairs(teams %>% filter(region == region_name) %>% arrange(slot))
  
  r32 <- c(predict_winner(sl[1],  sl[2]),  predict_winner(sl[3],  sl[4]),
           predict_winner(sl[5],  sl[6]),  predict_winner(sl[7],  sl[8]),
           predict_winner(sl[9],  sl[10]), predict_winner(sl[11], sl[12]),
           predict_winner(sl[13], sl[14]), predict_winner(sl[15], sl[16]))
  s16 <- c(predict_winner(r32[1], r32[2]), predict_winner(r32[3], r32[4]),
           predict_winner(r32[5], r32[6]), predict_winner(r32[7], r32[8]))
  e8  <- c(predict_winner(s16[1], s16[2]), predict_winner(s16[3], s16[4]))
  champ <- predict_winner(e8[1], e8[2])
  
  list(round64 = sapply(pairs, paste, collapse = " vs "),
       round32 = r32, sweet16 = s16, elite8 = e8, champ = champ)
}

regions  <- c("East", "South", "West", "Midwest")
predicted <- lapply(regions, predict_region)
names(predicted) <- regions

ff1 <- predict_winner(predicted$East$champ,  predicted$West$champ)
ff2 <- predict_winner(predicted$South$champ, predicted$Midwest$champ)
champion_pick <- predict_winner(ff1, ff2)
```

