# Probabilistic Bracket

The deterministic bracket above always picks the favorite, which underrepresents upsets relative to historical rates. A more realistic — and strategically useful — approach constructs a bracket by sampling game outcomes according to their actual win probabilities. Under this method a 12-seed with a 35% chance of winning gets picked 35% of the time, naturally producing a bracket that reflects the true uncertainty of the tournament.

```{r probabilistic-bracket}
# Build one bracket by sampling each game probabilistically
prob_game <- function(t1, t2) {
  p1 <- 1 / (1 + exp(-(em_vec[t1] - em_vec[t2]) / 10))
  if (runif(1) < p1) t1 else t2
}

prob_region <- function(region_name) {
  sl <- region_slots[[region_name]]
  r32 <- c(prob_game(sl[1],  sl[2]),  prob_game(sl[3],  sl[4]),
           prob_game(sl[5],  sl[6]),  prob_game(sl[7],  sl[8]),
           prob_game(sl[9],  sl[10]), prob_game(sl[11], sl[12]),
           prob_game(sl[13], sl[14]), prob_game(sl[15], sl[16]))
  s16 <- c(prob_game(r32[1], r32[2]), prob_game(r32[3], r32[4]),
           prob_game(r32[5], r32[6]), prob_game(r32[7], r32[8]))
  e8  <- c(prob_game(s16[1], s16[2]), prob_game(s16[3], s16[4]))
  champ <- prob_game(e8[1], e8[2])
  list(round32 = r32, sweet16 = s16, elite8 = e8, champ = champ)
}

set.seed(42)
pb <- lapply(regions, prob_region)
names(pb) <- regions

pb_ff1   <- prob_game(pb$East$champ,  pb$West$champ)
pb_ff2   <- prob_game(pb$South$champ, pb$Midwest$champ)
pb_champ <- prob_game(pb_ff1, pb_ff2)
```

