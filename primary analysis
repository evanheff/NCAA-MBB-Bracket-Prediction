# Monte Carlo Simulation

The tournament bracket is structured with 4 regions of 16 teams. Within each region, the standard NCAA slot pairing applies:

- Round of 64: (1v16), (8v9), (5v12), (4v13), (6v11), (3v14), (7v10), (2v15)
- Winners advance through region to a Final Four
- Final Four: East vs. West, South vs. Midwest (semifinal pairings)
- Championship: Final Four winners meet

```{r simulate-region}
# ── Fast lookup: named vector of AdjEM, indexed by team name ──────────────────
em_vec <- setNames(teams$adj_em, teams$team)

# Slot-based bracket pairing for a region (16 teams, slots 1–16)
get_round64_pairs <- function(region_teams) {
  slot_order <- region_teams %>% arrange(slot)
  pairs <- list(
    c(1, 2),   # 1 vs 16
    c(3, 4),   # 8 vs 9
    c(5, 6),   # 5 vs 12
    c(7, 8),   # 4 vs 13
    c(9, 10),  # 6 vs 11
    c(11, 12), # 3 vs 14
    c(13, 14), # 7 vs 10
    c(15, 16)  # 2 vs 15
  )
  lapply(pairs, function(p) slot_order$team[p])
}

# ── O(1) game simulation using pre-built named vector ─────────────────────────
sim_game_fast <- function(t1, t2) {
  p1 <- 1 / (1 + exp(-(em_vec[t1] - em_vec[t2]) / 10))
  if (runif(1) < p1) t1 else t2
}

# ── Simulate one region, returns advancement vectors (not lists) ───────────────
simulate_region_fast <- function(region_slots) {
  # region_slots: character vector of 16 team names in slot order
  
  # R64 — 8 games
  r32 <- c(
    sim_game_fast(region_slots[1],  region_slots[2]),
    sim_game_fast(region_slots[3],  region_slots[4]),
    sim_game_fast(region_slots[5],  region_slots[6]),
    sim_game_fast(region_slots[7],  region_slots[8]),
    sim_game_fast(region_slots[9],  region_slots[10]),
    sim_game_fast(region_slots[11], region_slots[12]),
    sim_game_fast(region_slots[13], region_slots[14]),
    sim_game_fast(region_slots[15], region_slots[16])
  )
  # R32 — 4 games
  s16 <- c(
    sim_game_fast(r32[1], r32[2]),
    sim_game_fast(r32[3], r32[4]),
    sim_game_fast(r32[5], r32[6]),
    sim_game_fast(r32[7], r32[8])
  )
  # Sweet 16 — 2 games
  e8 <- c(
    sim_game_fast(s16[1], s16[2]),
    sim_game_fast(s16[3], s16[4])
  )
  # Elite Eight — 1 game
  champ <- sim_game_fast(e8[1], e8[2])
  
  list(r32 = r32, s16 = s16, e8 = e8, champ = champ)
}

# ── Pre-extract slot vectors for each region (done once, outside the loop) ────
region_slots <- lapply(c("East","South","West","Midwest"), function(r) {
  teams %>% filter(region == r) %>% arrange(slot) %>% pull(team)
})
names(region_slots) <- c("East","South","West","Midwest")

# Keep get_round64_pairs available for display sections below
```

```{r run-simulations}
set.seed(42)
n_sims <- 100000

all_teams <- teams$team
n_teams   <- length(all_teams)

# Integer accumulator matrix — rows = teams, cols = rounds
adv_mat <- matrix(0L, nrow = n_teams, ncol = 6,
                  dimnames = list(all_teams,
                                  c("round32","sweet16","elite8","final4","finals","champion")))

# ── Main simulation loop ───────────────────────────────────────────────────────
for (i in seq_len(n_sims)) {
  
  east    <- simulate_region_fast(region_slots$East)
  south   <- simulate_region_fast(region_slots$South)
  west    <- simulate_region_fast(region_slots$West)
  midwest <- simulate_region_fast(region_slots$Midwest)
  
  # Vectorized accumulation — index by team name, add whole vectors at once
  adv_mat[east$r32,    "round32"] <- adv_mat[east$r32,    "round32"] + 1L
  adv_mat[south$r32,   "round32"] <- adv_mat[south$r32,   "round32"] + 1L
  adv_mat[west$r32,    "round32"] <- adv_mat[west$r32,    "round32"] + 1L
  adv_mat[midwest$r32, "round32"] <- adv_mat[midwest$r32, "round32"] + 1L
  
  adv_mat[east$s16,    "sweet16"] <- adv_mat[east$s16,    "sweet16"] + 1L
  adv_mat[south$s16,   "sweet16"] <- adv_mat[south$s16,   "sweet16"] + 1L
  adv_mat[west$s16,    "sweet16"] <- adv_mat[west$s16,    "sweet16"] + 1L
  adv_mat[midwest$s16, "sweet16"] <- adv_mat[midwest$s16, "sweet16"] + 1L
  
  adv_mat[east$e8,    "elite8"] <- adv_mat[east$e8,    "elite8"] + 1L
  adv_mat[south$e8,   "elite8"] <- adv_mat[south$e8,   "elite8"] + 1L
  adv_mat[west$e8,    "elite8"] <- adv_mat[west$e8,    "elite8"] + 1L
  adv_mat[midwest$e8, "elite8"] <- adv_mat[midwest$e8, "elite8"] + 1L
  
  adv_mat[east$champ,    "final4"] <- adv_mat[east$champ,    "final4"] + 1L
  adv_mat[south$champ,   "final4"] <- adv_mat[south$champ,   "final4"] + 1L
  adv_mat[west$champ,    "final4"] <- adv_mat[west$champ,    "final4"] + 1L
  adv_mat[midwest$champ, "final4"] <- adv_mat[midwest$champ, "final4"] + 1L
  
  # Final Four: East vs West, South vs Midwest
  ff1 <- sim_game_fast(east$champ,  west$champ)
  ff2 <- sim_game_fast(south$champ, midwest$champ)
  adv_mat[ff1, "finals"] <- adv_mat[ff1, "finals"] + 1L
  adv_mat[ff2, "finals"] <- adv_mat[ff2, "finals"] + 1L
  
  champ <- sim_game_fast(ff1, ff2)
  adv_mat[champ, "champion"] <- adv_mat[champ, "champion"] + 1L
}

# Convert to probabilities
prob_mat <- adv_mat / n_sims

results_df <- as.data.frame(prob_mat) %>%
  rownames_to_column("team") %>%
  left_join(select(teams, team, seed, region), by = "team") %>%
  arrange(region, seed) %>%
  mutate(across(round32:champion, ~ scales::percent(., accuracy = 0.1)))
```

